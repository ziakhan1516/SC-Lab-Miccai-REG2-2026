# Single source of truth for evaluation runtime and local test settings.
# Sourced by config.sh; do_build.sh passes matching values as Docker build-args.

# Image / build
DOCKER_IMAGE_TAG=reg26-evaluation-sample

# Evaluation runtime (container mount layout)
GRAND_CHALLENGE_MAX_WORKERS=
JUDGE_DEVICE=auto
JUDGE_MODEL_REL=Qwen3-8B
JUDGE_MODEL_PATH=/opt/ml/input/data/ground_truth/Qwen3-8B

# Judge model download (host only — used by download_model_weights.sh)
JUDGE_MODEL_REPO_ID=Qwen/Qwen3-8B
# Optional: set for faster Hugging Face downloads (or export HF_TOKEN in the shell)
HF_TOKEN=
EMBEDDING_MODEL=NeuML/pubmedbert-base-embeddings
INCLUDE_PER_CASE_RESULTS=1
INCLUDE_EVALUATION_DETAILS=0

# Local test only
USE_GPUS=auto
